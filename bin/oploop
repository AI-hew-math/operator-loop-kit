#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  oploop clone <git_url> <name> [base_dir]
  oploop -h|--help

Defaults:
  base_dir: "$HOME/OneDrive - postech.ac.kr/Claude_projects/projects"

Behavior:
  - clones into <base_dir>/<name>.rev
  - runs this kit's install.sh against the .rev repo
  - creates baseline commit once if install produced changes
  - attempts push to origin/main (warns and continues on failure)
  - adds a worktree <base_dir>/<name>.dev on branch ai/claude from local main
USAGE
}

cmd="${1:-}"
if [ -z "$cmd" ] || [ "$cmd" = "-h" ] || [ "$cmd" = "--help" ]; then
  usage
  exit 0
fi
shift || true

case "$cmd" in
  clone)
    git_url="${1:-}"
    name="${2:-}"
    base_dir="${3:-$HOME/OneDrive - postech.ac.kr/Claude_projects/projects}"

    if [ -z "$git_url" ] || [ -z "$name" ]; then
      usage
      exit 2
    fi

    mkdir -p "$base_dir"

    rev_dir="${base_dir}/${name}.rev"
    dev_dir="${base_dir}/${name}.dev"

    if [ -e "$rev_dir" ] || [ -e "$dev_dir" ]; then
      echo "ERROR: target path already exists:" >&2
      echo "  $rev_dir" >&2
      echo "  $dev_dir" >&2
      exit 1
    fi

    # Resolve kit root based on this script location.
    script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    kit_root="$(cd -- "$script_dir/.." && pwd)"
    install_sh="${kit_root}/install.sh"

    if [ ! -f "$install_sh" ]; then
      echo "ERROR: install.sh not found next to bin/oploop" >&2
      echo "  expected: $install_sh" >&2
      exit 1
    fi

    git clone "$git_url" "$rev_dir"

    # Install operator loop assets into the .rev repo using this kit's install.sh.
    bash "$install_sh" "$rev_dir"

    baseline_msg="chore: baseline operator-loop install"
    if [ -n "$(git -C "$rev_dir" status --porcelain)" ]; then
      if git -C "$rev_dir" log --format=%s --all | grep -Fxq "$baseline_msg"; then
        echo "INFO: baseline commit already exists; skipping auto-commit."
      else
        git -C "$rev_dir" add -A
        git -C "$rev_dir" commit -m "$baseline_msg"
      fi
    else
      echo "INFO: no install changes; skipping baseline commit."
    fi

    if git -C "$rev_dir" remote get-url origin >/dev/null 2>&1; then
      git -C "$rev_dir" push origin main || echo "WARN: push failed (likely no permission). Continue."
    fi

    if ! git -C "$rev_dir" rev-parse --verify -q main >/dev/null; then
      echo "ERROR: local branch 'main' not found in $rev_dir" >&2
      exit 1
    fi

    # Add a sibling worktree for .dev from local main so it works even if push fails.
    git -C "$rev_dir" worktree add -B ai/claude "$dev_dir" main

    echo "REV=${rev_dir}"
    echo "DEV=${dev_dir}"
    ;;
  *)
    usage
    exit 2
    ;;
esac
