#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  oploop clone <git_url> <name> [base_dir]

Defaults:
  base_dir: "$HOME/OneDrive - postech.ac.kr/Claude_projects/projects"

Behavior:
  - clones into <base_dir>/<name>.rev
  - adds a worktree <base_dir>/<name>.dev on branch ai/claude from origin/main
  - runs this kit's install.sh against the .rev repo
USAGE
}

cmd="${1:-}"
if [ -z "$cmd" ]; then
  usage
  exit 2
fi
shift || true

case "$cmd" in
  clone)
    git_url="${1:-}"
    name="${2:-}"
    base_dir="${3:-$HOME/OneDrive - postech.ac.kr/Claude_projects/projects}"

    if [ -z "$git_url" ] || [ -z "$name" ]; then
      usage
      exit 2
    fi

    rev_dir="${base_dir}/${name}.rev"
    dev_dir="${base_dir}/${name}.dev"

    if [ -e "$rev_dir" ] || [ -e "$dev_dir" ]; then
      echo "ERROR: target path already exists:" >&2
      echo "  $rev_dir" >&2
      echo "  $dev_dir" >&2
      exit 1
    fi

    # Resolve kit root based on this script location.
    script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    kit_root="$(cd -- "$script_dir/.." && pwd)"

    git clone "$git_url" "$rev_dir"

    # In the .rev repo, add a sibling worktree for .dev.
    (
      cd "$rev_dir"
      git worktree add -B ai/claude "../${name}.dev" origin/main
    )

    # Install operator loop assets into the .rev repo using this kit's install.sh.
    bash "$kit_root/install.sh" "$rev_dir"

    echo "REV=${rev_dir}"
    echo "DEV=${dev_dir}"
    ;;
  *)
    usage
    exit 2
    ;;
esac
